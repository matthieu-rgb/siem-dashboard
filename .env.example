# ============================================================
# SIEM Dashboard - Environment Configuration
# Copy to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- App ---
APP_VERSION=0.1.0
DEBUG=false

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# JWT token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# SQLite path inside the container. Volume mounted at /app/data.
DATABASE_URL=sqlite+aiosqlite:///./data/siem.db

# --- Wazuh Manager API ---
# The REST API runs on port 55000 by default.
# Use the Wazuh indexer user (wazuh-wui) or a dedicated API user.
WAZUH_HOST=https://your-wazuh-manager:55000
WAZUH_USER=wazuh
WAZUH_PASS=your-wazuh-api-password

# --- Wazuh Indexer (OpenSearch) ---
# Default port is 9200. Basic auth via admin user.
WAZUH_INDEXER_HOST=https://your-wazuh-manager:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=your-indexer-password

# --- CORS ---
# Comma-separated list of allowed origins.
# In dev: http://localhost:8080,http://localhost:5173
# In prod: https://your-domain.com
CORS_ORIGINS=http://localhost:8080
